<rvt-scroll-snap>
	<button class="rvt-button rvt-button--icon-only" data-prev hidden>
		<rvt-icon name="chevron-left"></rvt-icon>
		<span class="rvt-sr-only">Previous</span>
	</button>
	<div data-content>
		<slot />
	</div>
	<button class="rvt-button rvt-button--icon-only" data-next hidden>
		<rvt-icon name="chevron-right"></rvt-icon>
		<span class="rvt-sr-only">Next</span>
	</button>
</rvt-scroll-snap>

<style is:global>
	rvt-scroll-snap {
		--offset: var(--rvt-size-4);
		--offset-n: calc(var(--offset) * -1);
		--size-button: var(--rvt-size-48);
		align-items: center;
		display: grid;
		grid-template-columns: auto 1fr auto;

		:is([data-prev], [data-next]) {
			--color-background: var(--rvt-color-theme-background);
			--color-background-hover: var(--rvt-color-theme-background-strong);
			--color-border: var(--rvt-color-theme-ui);
			--color-border-hover: var(--rvt-color-theme-ui);
			align-self: stretch;
			visibility: hidden;
			z-index: var(--rvt-z-index-100);

			&:not([hidden]) {
				visibility: visible;
			}
		}

		[data-prev] {
			box-shadow: var(--offset-n) 0 0 0 var(--rvt-color-theme-background);
			grid-column: 1 / 2;
			grid-row: 1 / 2;
		}

		[data-content] {
			display: flex;
			grid-column: 1 / -1;
			grid-row: 1 / 2;
			overflow-x: auto;
			padding: var(--offset);
			margin: var(--offset-n);
			scroll-behavior: smooth;
			scroll-padding: calc(var(--size-button) + var(--offset));
			scroll-snap-type: inline mandatory;
			scrollbar-width: none;
		}

		[data-next] {
			box-shadow: var(--offset) 0 0 0 var(--rvt-color-theme-background);
			grid-column: -2 / -1;
			grid-row: 1 / 2;
		}
	}
</style>

<script>
	function handleScrollSnap(root: any) {
		if (!(root instanceof HTMLElement)) {
			return;
		}

		const container = root.closest("rvt-scroll-snap");

		if (!container) {
			return;
		}

		const content = container.querySelector("[data-content]");
		const prev = container.querySelector("[data-prev]") as HTMLElement;
		const next = container.querySelector("[data-next]") as HTMLElement;

		if (!content) {
			return;
		}

		const maxScroll = content.scrollWidth - content.clientWidth;
		const perc = maxScroll > 0 ? content.scrollLeft / maxScroll : 0;
		const tolerance = 0.01;
		const isScrollable = maxScroll > 0;
		const isAtStart = perc <= 0 + tolerance;
		const isAtEnd = perc >= 1 - tolerance;

		if (prev) {
			prev.hidden = !isScrollable || isAtStart;
		}
		if (next) {
			next.hidden = !isScrollable || isAtEnd;
		}
	}

	function handleAllScrollSnap() {
		document.querySelectorAll("rvt-scroll-snap").forEach(handleScrollSnap);
	}

	document.addEventListener(
		"scroll",
		(event) => {
			handleScrollSnap(event.target);
		},
		{ capture: true, passive: true },
	);

	const resizeObserver = new ResizeObserver(handleAllScrollSnap);
	resizeObserver.observe(document.body);

	document.addEventListener("click", (event) => {
		if (!(event.target instanceof HTMLElement)) {
			return;
		}

		const button = event.target.closest(
			"rvt-scroll-snap [data-prev], rvt-scroll-snap [data-next]",
		);

		if (!button) {
			return;
		}

		const container = button.closest("rvt-scroll-snap");
		const content = container?.querySelector("[data-content]");

		if (!content) {
			return;
		}

		const direction = button.matches("[data-prev]") ? -1 : 1;
		const contentWidth = content.scrollWidth - button.clientWidth * 2;
		const step = contentWidth * direction * 0.3;
		content.scrollBy({ left: step, behavior: "smooth" });
	});
</script>
