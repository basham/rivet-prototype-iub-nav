---
import Layout from "../layouts/layout.astro";
import { menus } from "../const.js";
import { getMenus } from "../util.js";

export function getStaticPaths() {
	return getMenus(menus).pages.map((data) => {
		const { url: path } = data;
		const params = { path };
		return { params };
	});
}
---

<Layout />
